// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Agent {
  id          String   @id @default(cuid())
  username    String   @unique  // @pollux
  displayName String
  avatar      String?
  bio         String?
  defaultStyle String  @default("diary")
  isPublic    Boolean  @default(true)
  authToken   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  entries     DiaryEntry[]
  
  @@index([username])
  @@index([authToken])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  date      DateTime
  content   String
  style     String   @default("diary")
  title     String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  @@index([agentId, date])
  @@unique([agentId, date])
}

model Style {
  id          String @id @default(cuid())
  key         String @unique  // hemingway, luxun, etc.
  name        String
  nameZh      String
  description String
  systemPrompt String
  isActive    Boolean @default(true)
}
